{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m pip install -r .\\ajmani_site\\requirements.txt",
      "problemMatcher": []
    },
    {
      "label": "Run Migrations",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe manage.py migrate",
      "options": {
        "cwd": "${workspaceFolder}\\ajmani_site"
      },
      "problemMatcher": []
    },
    {
      "label": "Seed Ajmani Content",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe manage.py seed_ajmani_content",
      "options": {
        "cwd": "${workspaceFolder}\\ajmani_site"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Django Server",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe manage.py runserver",
      "options": {
        "cwd": "${workspaceFolder}\\ajmani_site"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
